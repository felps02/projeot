PORT=3000

# Banco de dados
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=psicossocial_db

# JWT - troque para uma string forte e secreta em producao
JWT_SECRET=troque_para_uma_string_forte
JWT_EXPIRES_IN=24h

# Administrador inicial (seed) - criado no primeiro start se nao houver admin
ADMIN_EMAIL=admin@psicossocial.local
ADMIN_NOME=Administrador
ADMIN_SENHA=Admin@123

# Logging: error | warn | info | debug
LOG_LEVEL=info

# CORS - lista de origens separadas por virgula, ou * para liberar tudo
CORS_ORIGINS=*

# Privacidade / LGPD
# Threshold k-anonymity: grupos com menos do que K membros sao suprimidos nos relatorios agregados
K_ANONYMITY_MIN=5

# NODE_ENV=production para producao (esconde stack traces, etc)
NODE_ENV=development
